{
  "manifest_version": 3,
  "name": "Jijira",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "icons": {
    "128": "icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches" : ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions":["activeTab", "scripting", "storage"],
  "host_permissions": ["https://open.er-api.com/*"],
  "options_page": "options.html"
}
