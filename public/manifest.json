{
  "manifest_version": 3,
  "name": "Jijira",
  "version": "1.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches" : ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions":["activeTab", "scripting", "storage"],
  "host_permissions": ["https://open.er-api.com/*"],
  "options_page": "options.html"
}
